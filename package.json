{
  "name": "deskhub",
  "version": "1.0.0",
  "description": "DeskHub - Support Ticket Dashboard",
  "main": "src/main.js",
  "scripts": {
    "api": "json-server --watch db.json --port 3001",
    "ui": "live-server . --port=8080 --open=public/index.html",
    "dev": "concurrently \"npm run api\" \"npm run ui\""
  },
  "dependencies": {
    "json-server": "^0.17.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "live-server": "^1.2.2"
  }
}
